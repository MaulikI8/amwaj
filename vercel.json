{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    },
    {
      "src": "fonts/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/api-docs(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/home",
      "dest": "backend/server.js"
    },
    {
      "src": "/index.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/products.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/products",
      "dest": "backend/server.js"
    },
    {
      "src": "/product-detail.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/product",
      "dest": "backend/server.js"
    },
    {
      "src": "/admin.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/admin",
      "dest": "backend/server.js"
    },
    {
      "src": "/cart.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/cart",
      "dest": "backend/server.js"
    },
    {
      "src": "/checkout.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/checkout",
      "dest": "backend/server.js"
    },
    {
      "src": "/wishlists.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/wishlists",
      "dest": "backend/server.js"
    },
    {
      "src": "/profile.html",
      "dest": "backend/server.js"
    },
    {
      "src": "/profile",
      "dest": "backend/server.js"
    },
    {
      "src": "/",
      "dest": "backend/server.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/fonts/(.*)",
      "dest": "/fonts/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    }
  ]
}
